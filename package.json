    "@neondatabase/serverless": "^1.0.2",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.1",
    "mammoth": "^1.12.0",
    "next": "^16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "^3.8.1",
    "toucan-js": "^4.1.1",
    "unpdf": "^1.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.60.0",
