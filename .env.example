# Neon Postgres
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Canonical site URL - used in sitemap, robots.txt, OG metadata
NEXT_PUBLIC_SITE_URL=https://volimto.sk

# Sentry error monitoring (optional)
SENTRY_DSN=

# Umami Cloud analytics - website ID from umami.is dashboard
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Admin panel
ADMIN_SECRET=change-me-in-production

# Cron secret - used by Vercel cron route authentication
CRON_SECRET=<generate with: openssl rand -hex 32>

# Resend - email sending for newsletter
RESEND_API_KEY=re_xxxxxxxxxxxx

# Stripe - API access billing
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxxxxxx

# Anthropic - AI narrative generation for /predikcia
ANTHROPIC_API_KEY=your_anthropic_api_key_here
